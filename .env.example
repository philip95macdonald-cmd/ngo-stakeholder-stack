# NGO Stakeholder Stack — Environment-Variablen
# Lokal kopieren: cp .env.example .env  und Werte einfüllen.
# .env ist .gitignored — niemals committen.

# ─── BREVO (Pflicht für brevo-sync) ─────────────────────────────────────
# Token-Generierung: https://app.brevo.com/security/api-keys
BREVO_API_KEY=xkeysib-DEIN-KEY-HIER

# ─── ABGEORDNETENWATCH (keine Auth nötig) ───────────────────────────────
# Public API — keine Variable nötig. Hier nur als Doku-Anker.

# ─── TWITTER / X (optional, für themen-monitor) ─────────────────────────
# Bearer-Token aus dem X-Developer-Portal
TWITTER_BEARER_TOKEN=

# ─── YOUTUBE DATA API v3 (optional) ─────────────────────────────────────
# Aus Google Cloud Console
YOUTUBE_API_KEY=

# ─── SMTP für Themen-Monitor-Reports und Krisen-Alerts ──────────────────
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USER=alerts@deine-ngo.org
SMTP_PASS=
SMTP_FROM=alerts@deine-ngo.org
SMTP_TO=team@deine-ngo.org

# ─── SLACK (optional, alternative Alert-Senke) ──────────────────────────
# Webhook-URL aus deinem Slack-Workspace
SLACK_WEBHOOK_URL=

# ─── LOG-LEVEL (DEBUG / INFO / WARNING / ERROR) ─────────────────────────
LOG_LEVEL=INFO

# ─── OUTPUT-VERZEICHNIS (relativ zum Repo-Root, default ./output) ───────
OUTPUT_DIR=./output
